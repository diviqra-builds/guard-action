{
  "name": "guard-action",
  "version": "1.0.0",
  "description": "Diviqra Guard GitHub Action for LLM prompt scanning",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@actions/core",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  },
  "allowScripts": {
    "esbuild@0.20.2": true
  }
}
